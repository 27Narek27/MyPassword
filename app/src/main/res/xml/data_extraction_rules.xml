<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ (API 31+) data-extraction rules.
    Mirrors backup_rules.xml: exclude everything from both cloud backup
    and device-to-device transfer.

    See: https://developer.android.com/about/versions/12/backup-restore#xml-changes
-->
<data-extraction-rules>

    <cloud-backup disableIfNoEncryptionCapabilities="true">
        <exclude domain="database"   path="passwords.db" />
        <exclude domain="database"   path="passwords.db-shm" />
        <exclude domain="database"   path="passwords.db-wal" />
        <exclude domain="sharedpref" path="." />
        <exclude domain="root"       path="." />
    </cloud-backup>

    <device-transfer>
        <exclude domain="database"   path="passwords.db" />
        <exclude domain="database"   path="passwords.db-shm" />
        <exclude domain="database"   path="passwords.db-wal" />
        <exclude domain="sharedpref" path="." />
        <exclude domain="root"       path="." />
    </device-transfer>

</data-extraction-rules>