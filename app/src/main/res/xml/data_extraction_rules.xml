<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>

    <cloud-backup disableIfNoEncryptionCapabilities="true">
        <exclude domain="database"   path="passwords.db" />
        <exclude domain="database"   path="passwords.db-shm" />
        <exclude domain="database"   path="passwords.db-wal" />
        <exclude domain="sharedpref" path="." />
        <exclude domain="root"       path="." />
    </cloud-backup>

    <device-transfer>
        <exclude domain="database"   path="passwords.db" />
        <exclude domain="database"   path="passwords.db-shm" />
        <exclude domain="database"   path="passwords.db-wal" />
        <exclude domain="sharedpref" path="." />
        <exclude domain="root"       path="." />
    </device-transfer>

</data-extraction-rules>
