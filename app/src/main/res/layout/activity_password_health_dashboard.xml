<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="20dp" android:background="#0f0f0f">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Password Health" android:textSize="22sp" android:textColor="#ffffff"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Слабые пароли" android:textColor="#c8c8c8"/>
    <TextView android:id="@+id/tvWeak" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#ff8080" android:textSize="28sp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Дубликаты" android:textColor="#c8c8c8"/>
    <TextView android:id="@+id/tvDuplicates" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#ffd280" android:textSize="28sp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Давно не менялись" android:textColor="#c8c8c8"/>
    <TextView android:id="@+id/tvStale" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#80b3ff" android:textSize="28sp"/>
</LinearLayout>