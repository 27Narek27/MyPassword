<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f0f0f"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="Password Health"
        android:textColor="#ffffff"
        android:textSize="22sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/cardWeak"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="#1a1a1a"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Слабые пароли"
            android:textColor="#c8c8c8" />

        <TextView
            android:id="@+id/tvWeak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#ff8080"
            android:textSize="28sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/cardDuplicates"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="#1a1a1a"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Дубликаты"
            android:textColor="#c8c8c8" />

        <TextView
            android:id="@+id/tvDuplicates"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#ffd280"
            android:textSize="28sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/cardStale"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1a1a1a"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Давно не менялись"
            android:textColor="#c8c8c8" />

        <TextView
            android:id="@+id/tvStale"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#80b3ff"
            android:textSize="28sp" />
    </LinearLayout>

</LinearLayout>
