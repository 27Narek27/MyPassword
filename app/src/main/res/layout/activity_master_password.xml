<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f0f0f"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvMasterPasswordTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:textColor="#c8c8c8"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvMasterPasswordSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:textColor="#4a4a4a"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/etMasterPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:autofillHints="password"
        android:background="@android:color/transparent"
        android:backgroundTint="#2a2a2a"
        android:inputType="textPassword"
        android:maxLines="1"
        android:minHeight="48dp"
        android:textColor="#c8c8c8"
        android:textColorHint="#3a3a3a" />

    <Button
        android:id="@+id/btnMasterPasswordAction"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:backgroundTint="#4a7a3a"
        android:textColor="#d4edca"
        android:textStyle="bold"
        android:textSize="15sp" />

</LinearLayout>