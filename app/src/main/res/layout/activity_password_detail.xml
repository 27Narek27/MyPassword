<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#99482A">

    <!-- Title -->
    <TextView
        android:text="Entry details"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#9CBA7F"
        android:layout_marginBottom="24dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Site label -->
    <TextView
        android:text="Site:"
        android:textSize="14sp"
        android:textColor="#809CBA7F"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Site value -->
    <TextView
        android:id="@+id/tvSite"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#9CBA7F"
        android:layout_marginBottom="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Login label -->
    <TextView
        android:text="Login:"
        android:textSize="14sp"
        android:textColor="#809CBA7F"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Login value -->
    <TextView
        android:id="@+id/tvLogin"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#9CBA7F"
        android:layout_marginBottom="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Password label -->
    <TextView
        android:text="Password:"
        android:textSize="14sp"
        android:textColor="#809CBA7F"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Password value -->
    <TextView
        android:id="@+id/tvPassword"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#9CBA7F"
        android:fontFamily="monospace"
        android:layout_marginBottom="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Show Password Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnShowPassword"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="32dp"
        android:text="Show password"
        android:textSize="15sp"
        android:textColor="#9CBA7F"
        android:textStyle="bold"
        app:backgroundTint="#7A3A22"
        app:strokeColor="#9CBA7F"
        app:strokeWidth="1dp"
        app:cornerRadius="14dp" />

    <!-- Edit Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEdit"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="8dp"
        android:text="Edit"
        android:textSize="15sp"
        android:textColor="#99482A"
        android:textStyle="bold"
        app:backgroundTint="#9CBA7F"
        app:cornerRadius="14dp" />

    <!-- Delete Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDelete"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Delete"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:backgroundTint="#8B1A1A"
        app:cornerRadius="14dp" />

</LinearLayout>
