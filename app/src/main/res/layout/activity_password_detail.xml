<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f0f0f"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:text="Детали записи"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#c8c8c8"
            android:layout_marginBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView android:text="НАЗВАНИЕ" android:textSize="11sp" android:textColor="#3a3a3a"
            android:letterSpacing="0.08"
            android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView android:id="@+id/tvSite" android:textSize="17sp" android:textStyle="bold"
            android:textColor="#c8c8c8" android:layout_marginBottom="16dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" />

        <TextView android:text="САЙТ (URL)" android:textSize="11sp" android:textColor="#3a3a3a"
            android:letterSpacing="0.08"
            android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView android:id="@+id/tvWebsiteUrl" android:textSize="14sp" android:textColor="#5090c0"
            android:layout_marginBottom="4dp" android:ellipsize="end" android:maxLines="1"
            android:layout_width="wrap_content" android:layout_height="wrap_content" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAutoLogin"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginBottom="16dp"
            android:text="Открыть и войти автоматически"
            android:textSize="13sp"
            android:textColor="#d4edca"
            android:textStyle="bold"
            android:visibility="gone"
            app:backgroundTint="#1e3a2a"
            app:strokeColor="#2a5a3a"
            app:strokeWidth="1dp"
            app:cornerRadius="10dp"
            app:icon="@drawable/ic_link"
            app:iconTint="#6b9e5a"
            app:iconSize="16dp"
            app:iconPadding="6dp" />

        <TextView android:text="ЛОГИН" android:textSize="11sp" android:textColor="#3a3a3a"
            android:letterSpacing="0.08"
            android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView android:id="@+id/tvLogin" android:textSize="17sp" android:textStyle="bold"
            android:textColor="#c8c8c8" android:layout_marginBottom="16dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" />

        <TextView android:text="ПАРОЛЬ" android:textSize="11sp" android:textColor="#3a3a3a"
            android:letterSpacing="0.08"
            android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView android:id="@+id/tvPassword" android:textSize="17sp" android:textStyle="bold"
            android:textColor="#c8c8c8" android:fontFamily="monospace" android:layout_marginBottom="8dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShowPassword"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="24dp"
            android:text="Показать пароль"
            android:textSize="14sp"
            android:textColor="#8a8a8a"
            android:textStyle="bold"
            app:backgroundTint="#161616"
            app:strokeColor="#2a2a2a"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPasswordHistory"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:text="История и откат"
            android:textSize="14sp"
            android:textColor="#d4edca"
            android:textStyle="bold"
            app:backgroundTint="#2a2a2a"
            app:strokeColor="#3f3f3f"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEdit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:text="Редактировать"
            android:textSize="14sp"
            android:textColor="#d4edca"
            android:textStyle="bold"
            app:backgroundTint="#4a7a3a"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDelete"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Удалить запись"
            android:textSize="14sp"
            android:textColor="#c06060"
            android:textStyle="bold"
            app:backgroundTint="#2a1515"
            app:strokeColor="#3a2020"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp" />

    </LinearLayout>
</ScrollView>