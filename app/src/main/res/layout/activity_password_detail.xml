<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#99482A"
    android:fillViewport="true">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">
        <TextView
            android:text="Entry Details"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#9CBA7F"
            android:layout_marginBottom="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <TextView
            android:text="Title"
            android:textSize="12sp"
            android:textColor="#809CBA7F"
            android:letterSpacing="0.08"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <TextView
            android:id="@+id/tvSite"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#9CBA7F"
            android:layout_marginBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <TextView
            android:text="Website URL"
            android:textSize="12sp"
            android:textColor="#809CBA7F"
            android:letterSpacing="0.08"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <TextView
            android:id="@+id/tvWebsiteUrl"
            android:textSize="16sp"
            android:textColor="#4FC3F7"
            android:layout_marginBottom="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAutoLogin"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="20dp"
            android:text="Open &amp; Auto-Login"
            android:textSize="14sp"
            android:textColor="#99482A"
            android:textStyle="bold"
            android:visibility="gone"
            app:backgroundTint="#4FC3F7"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_link"
            app:iconTint="#99482A"
            app:iconSize="18dp"
            app:iconPadding="6dp" />
        <TextView
            android:text="Login"
            android:textSize="12sp"
            android:textColor="#809CBA7F"
            android:letterSpacing="0.08"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <TextView
            android:id="@+id/tvLogin"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#9CBA7F"
            android:layout_marginBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <TextView
            android:text="Password"
            android:textSize="12sp"
            android:textColor="#809CBA7F"
            android:letterSpacing="0.08"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <TextView
            android:id="@+id/tvPassword"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#9CBA7F"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShowPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="32dp"
            android:text="Show Password"
            android:textSize="15sp"
            android:textColor="#9CBA7F"
            android:textStyle="bold"
            app:backgroundTint="#7A3A22"
            app:strokeColor="#9CBA7F"
            app:strokeWidth="1dp"
            app:cornerRadius="14dp" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEdit"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="8dp"
            android:text="Edit"
            android:textSize="15sp"
            android:textColor="#99482A"
            android:textStyle="bold"
            app:backgroundTint="#9CBA7F"
            app:cornerRadius="14dp" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDelete"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Delete"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:backgroundTint="#8B1A1A"
            app:cornerRadius="14dp" />
    </LinearLayout>
</ScrollView>