<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0f0f0f"
        android:padding="16dp">

        <!-- Question 1 -->
        <TextView
            android:id="@+id/tvSecQ1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#6b9e5a"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etSecA1"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/edit_text_bg"
            android:hint="Ваш ответ"
            android:textColor="#c8c8c8"
            android:textColorHint="#3a3a3a"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:inputType="text" />

        <!-- Question 2 -->
        <TextView
            android:id="@+id/tvSecQ2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#6b9e5a"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etSecA2"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/edit_text_bg"
            android:hint="Ваш ответ"
            android:textColor="#c8c8c8"
            android:textColorHint="#3a3a3a"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:inputType="text" />

        <!-- Question 3 -->
        <TextView
            android:id="@+id/tvSecQ3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#6b9e5a"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etSecA3"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/edit_text_bg"
            android:hint="Ваш ответ"
            android:textColor="#c8c8c8"
            android:textColorHint="#3a3a3a"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:inputType="text" />

        <!-- Question 4 -->
        <TextView
            android:id="@+id/tvSecQ4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#6b9e5a"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etSecA4"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/edit_text_bg"
            android:hint="Ваш ответ"
            android:textColor="#c8c8c8"
            android:textColorHint="#3a3a3a"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:inputType="text" />

    </LinearLayout>
</ScrollView>