<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f0f0f"
    android:fillViewport="true">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Добавить пароль"
            android:textColor="#c8c8c8"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="#2a2a2a"
            app:boxBackgroundColor="#161616"
            app:hintTextColor="#4a4a4a"
            app:boxBackgroundMode="outline"
            app:cornerRadius="10dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSite"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Название / сайт"
                android:textColor="#c8c8c8"
                android:textColorHint="#3a3a3a"
                android:minHeight="48dp"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="#2a2a2a"
            app:boxBackgroundColor="#161616"
            app:hintTextColor="#4a4a4a"
            app:boxBackgroundMode="outline"
            app:cornerRadius="10dp"
            app:startIconDrawable="@drawable/ic_link"
            app:startIconTint="#3a3a3a"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etWebsiteUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="URL сайта (https://example.com)"
                android:imeOptions="actionNext"
                android:inputType="textUri"
                android:minHeight="48dp"
                android:textColor="#c8c8c8"
                android:textColorHint="#3a3a3a" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="#2a2a2a"
            app:boxBackgroundColor="#161616"
            app:hintTextColor="#4a4a4a"
            app:boxBackgroundMode="outline"
            app:cornerRadius="10dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Логин / имя пользователя"
                android:textColor="#c8c8c8"
                android:textColorHint="#3a3a3a"
                android:minHeight="48dp"
                android:inputType="textEmailAddress" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:boxStrokeColor="#2a2a2a"
            app:boxBackgroundColor="#161616"
            app:hintTextColor="#4a4a4a"
            app:boxBackgroundMode="outline"
            app:cornerRadius="10dp"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="#4a4a4a"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Пароль"
                android:inputType="textPassword"
                android:textColor="#c8c8c8"
                android:textColorHint="#3a3a3a"
                android:minHeight="48dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGeneratePassword"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="10dp"
            android:text="Сгенерировать надёжный пароль"
            android:textSize="14sp"
            android:textColor="#d4edca"
            android:textStyle="bold"
            app:backgroundTint="#1e3a2a"
            app:strokeColor="#2a5a3a"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_lock"
            app:iconTint="#6b9e5a"
            app:iconSize="16dp"
            app:iconPadding="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Сохранить"
            android:textSize="15sp"
            android:textColor="#d4edca"
            android:textStyle="bold"
            app:backgroundTint="#4a7a3a"
            app:cornerRadius="12dp" />
    </LinearLayout>
</ScrollView>