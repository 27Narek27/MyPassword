<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#99482A"
    android:fillViewport="true">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Password"
            android:textColor="#9CBA7F"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="#9CBA7F"
            app:boxBackgroundColor="#7A3A22"
            app:hintTextColor="#9CBA7F"
            app:boxBackgroundMode="outline"
            app:cornerRadius="10dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSite"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Title / Site Name"
                android:textColor="#9CBA7F"
                android:textColorHint="#809CBA7F"
                android:minHeight="48dp"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="#9CBA7F"
            app:boxBackgroundColor="#7A3A22"
            app:hintTextColor="#9CBA7F"
            app:boxBackgroundMode="outline"
            app:cornerRadius="10dp"
            app:startIconDrawable="@drawable/ic_link"
            app:startIconTint="#9CBA7F"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etWebsiteUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Website URL (e.g. https://example.com)"
                android:textColor="#9CBA7F"
                android:textColorHint="#809CBA7F"
                android:minHeight="48dp"
                android:inputType="textUri"
                android:imeOptions="actionNext" />
        </com.google.android.material.textfield.TextInputLayout>
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="#9CBA7F"
            app:boxBackgroundColor="#7A3A22"
            app:hintTextColor="#9CBA7F"
            app:boxBackgroundMode="outline"
            app:cornerRadius="10dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Login / Username"
                android:textColor="#9CBA7F"
                android:textColorHint="#809CBA7F"
                android:minHeight="48dp"
                android:inputType="textEmailAddress" />
        </com.google.android.material.textfield.TextInputLayout>
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:boxStrokeColor="#9CBA7F"
            app:boxBackgroundColor="#7A3A22"
            app:hintTextColor="#9CBA7F"
            app:boxBackgroundMode="outline"
            app:cornerRadius="10dp"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="#9CBA7F"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Password"
                android:inputType="textPassword"
                android:textColor="#9CBA7F"
                android:textColorHint="#809CBA7F"
                android:minHeight="48dp" />
        </com.google.android.material.textfield.TextInputLayout>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGeneratePassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:text="Generate Strong Password"
            android:textSize="15sp"
            android:textColor="#99482A"
            android:textStyle="bold"
            app:backgroundTint="#9CBA7F"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_lock"
            app:iconTint="#99482A"
            app:iconSize="18dp"
            app:iconPadding="8dp" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Save"
            android:textSize="16sp"
            android:textColor="#99482A"
            android:textStyle="bold"
            app:backgroundTint="#9CBA7F"
            app:cornerRadius="14dp" />
    </LinearLayout>
</ScrollView>